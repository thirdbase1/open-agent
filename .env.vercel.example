# Vercel environment variables needed for `feat/vercel-migration`.
# Create these in your Vercel project's Environment Variables UI, OR
# let the linked integrations (Vercel Postgres / KV / Blob) auto-inject.
#
# Production & Preview environment is recommended for both services.

# -- Data layer ----------------------------------------------------------
DATABASE_URL=postgres://...                          # Vercel Postgres
REDIS_URL=rediss://...                                # Vercel KV (Redis-compatible)
BLOB_READ_WRITE_TOKEN=...                             # Vercel Blob

# -- AI layer --------------------------------------------------------------
# All AI calls now route through Vercel AI Gateway.
AI_GATEWAY_API_KEY=...
# Default model id used by the migrated gateway provider.
AI_GATEWAY_DEFAULT_MODEL=openai/gpt-5

# -- Sandbox layer ----------------------------------------------------------
# Replaces E2B_API_KEY. Used by @vercel/sandbox.
SANDBOX_API_KEY=...

# -- Public ----------------------------------------------------------------
NEXT_PUBLIC_API_BASE=/api
NEXT_PUBLIC_WS_BASE=/api/ws
