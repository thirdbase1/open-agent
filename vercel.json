{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "server": {
      "root": ".",
      "runtime": "container",
      "framework": null,
      "entrypoint": "Dockerfile.vercel"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "service": "server"
      }
    }
  ]
}
